@model CatalogoDeProductos.Model.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<h1 class="text-danger mb-3">Eliminar Producto</h1>

<h3>¿Está seguro que desea eliminar este producto?</h3>

<div>
    <h4>Detalle del Producto</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Nombre</dd>

        <dt class="col-sm-2">Precio</dt>
        <dd class="col-sm-10">@Model.Precio.ToString("C")</dd>

        <dt class="col-sm-2">Categoría</dt>
        <dd class="col-sm-10">@Model.Categoria</dd>

        <dt class="col-sm-2">Estado</dt>
        <dd class="col-sm-10">
            @(Model.Activo ? "Activo" : "Inactivo")
        </dd>

        <dt class="col-sm-2">Fecha Ingreso</dt>
        <dd class="col-sm-10">@Model.FechaIngreso.ToString("dd/MM/yyyy")</dd>
    </dl>

    <form asp-action="Delete">
        <!-- 🔑 Id oculto (CRÍTICO) -->
        <input type="hidden" asp-for="Id" />

        <input type="submit" value="Eliminar" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>