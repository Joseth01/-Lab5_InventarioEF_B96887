@model IEnumerable<CatalogoDeProductos.Model.Producto>

@{
    ViewData["Title"] = "Productos";
}

<h1 class="mb-3">Lista de Productos</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">➕ Nuevo Producto</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No hay productos registrados.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Id)</th>
                <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                <th>@Html.DisplayNameFor(model => model.Precio)</th>
                <th>@Html.DisplayNameFor(model => model.Categoria)</th>
                <th>@Html.DisplayNameFor(model => model.Activo)</th>
                <th>@Html.DisplayNameFor(model => model.FechaIngreso)</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Nombre</td>
                    <td>@item.Precio.ToString("C")</td>
                    <td>@item.Categoria</td>
                    <td>
                        @(item.Activo ? "Activo" : "Inactivo")
                    </td>
                    <td>@item.FechaIngreso.ToString("dd/MM/yyyy")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}